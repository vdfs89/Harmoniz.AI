# Exemplo de arquivo Secrets para Streamlit Cloud
# ================================================
#
# IMPORTANTE: Este é APENAS um exemplo.
# 
# Para usar no Streamlit Cloud:
# 1. Vá em https://share.streamlit.io
# 2. Clique no seu app "harmonizai"
# 3. Clique em "..." (três pontos) → Settings
# 4. Abra a aba "Secrets"
# 5. Cole TODO o conteúdo abaixo (sem os comentários)
# 6. Substitua os valores pelos seus valores reais
# 7. Clique "Save"
#
# Para usar localmente:
# 1. Copie este arquivo para .streamlit/secrets.toml
# 2. Descomente as linhas
# 3. Substitua pelos seus valores reais
# ================================================

# API Keys (OBRIGATÓRIAS)
OPENAI_API_KEY = "sk_..."
GROQ_API_KEY = "gsk_..."
GEMINI_API_KEY = "AIzaSy..."

# Configuração de Modelos
OPENAI_MODEL = "gpt-4o-mini"
GROQ_MODEL = "llama-3.3-70b-versatile"
GEMINI_MODEL = "gemini-2.0-flash"
JUDGE_PROVIDER = "openai"
JUDGE_MODEL = "gpt-4o-mini"

# Caminhos de Dados
WINE_DATA_PATH = "data/raw/wines_from_winecombr.xlsx"
VECTOR_DB_PATH = "data/processed/chroma_db"

# LangSmith (OPCIONAL - para observabilidade)
LANGCHAIN_TRACING_V2 = "false"
# LANGCHAIN_API_KEY = "ls_..."
# LANGCHAIN_PROJECT = "harmoniz-ai-streamlit"
