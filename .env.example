# Configuracoes de API - LLMs
OPENAI_API_KEY=sk_...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIzaSy...

# Modelos a usar
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini

# Caminhos de dados
WINE_DATA_PATH=data/raw/wines_from_winecombr.xlsx
VECTOR_DB_PATH=data/processed/chroma_db
RAG_TOP_K=6

# ============================================================================
# LANGSMITH — MLOps/Observabilidade em Producao
# ============================================================================
# 
# LangSmith permite rastrear, debugar e otimizar chains em produção.
# 
# Setup:
# 1. Crie conta em https://smith.langchain.com
# 2. Gere uma API Key no dashboard
# 3. Defina as variáveis abaixo
# 4. Execute: python src/utils/observability_setup.py
#

# Ativar rastreamento automático (true/false)
LANGCHAIN_TRACING_V2=true

# API Key do LangSmith (obtém em smith.langchain.com)
LANGCHAIN_API_KEY=ls_...

# Nome do projeto (aparece em smith.langchain.com/projects/)
LANGCHAIN_PROJECT=harmoniz-ai-production

# ============================================================================
# OPCOES AVANCADAS
# ============================================================================

# Endpoint customizado (se usar self-hosted)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Nivel de logging (debug|info|warning)
LANGCHAIN_DEBUG=false

# Samplear apenas X% das requests (economiza quota)
LANGCHAIN_SAMPLE_RATE=1.0
